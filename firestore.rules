rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, email, displayName, photoURL, role (customer|vendor|admin), createdAt
    //
    // Collection: vendors
    // Fields: uid, storeName, description, logoURL, status (pending|approved|suspended), revenue, createdAt
    //
    // Collection: products
    // Fields: vendorId, name, description, price, category, images, stock, rating, reviewCount, createdAt
    //
    // Collection: categories
    // Fields: name, slug, icon
    //
    // Collection: orders
    // Fields: customerId, totalAmount, status, shippingAddress, paymentId, createdAt
    //
    // Collection: orders/{orderId}/items
    // Fields: orderId, productId, vendorId, quantity, priceAtPurchase
    //
    // Collection: products/{productId}/reviews
    // Fields: productId, customerId, customerName, rating, comment, createdAt
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "aniemaenya@gmail.com" && request.auth.token.email_verified == true));
    }

    function isVendor() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'vendor';
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.role in ['customer', 'vendor', 'admin'] &&
             data.email is string && data.email.size() < 255;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['vendorId', 'name', 'price', 'category', 'stock', 'createdAt']) &&
             data.vendorId == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.price is number && data.price >= 0 &&
             data.stock is int && data.stock >= 0;
    }

    function isValidReview(data) {
      return data.keys().hasAll(['productId', 'customerId', 'rating', 'createdAt']) &&
             data.customerId == request.auth.uid &&
             data.rating is int && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() < 1000;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (request.resource.data.role != 'admin' || isAdmin());
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role;
    }

    match /vendors/{vendorId} {
      allow read: if true; // Publicly viewable
      allow create: if isOwner(vendorId) && isVendor();
      allow update: if (isOwner(vendorId) || isAdmin());
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isVendor() && isValidProduct(request.resource.data);
      allow update: if (isAuthenticated() && resource.data.vendorId == request.auth.uid && isValidProduct(request.resource.data)) || isAdmin();
      allow delete: if (isAuthenticated() && resource.data.vendorId == request.auth.uid) || isAdmin();

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isAuthenticated() && isValidReview(request.resource.data);
        allow update, delete: if isOwner(resource.data.customerId) || isAdmin();
      }
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.customerId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.customerId == request.auth.uid;
      allow update: if isAdmin(); // Only admin can update status (e.g. shipped)

      match /items/{itemId} {
        allow read: if isAuthenticated() && (get(/databases/$(database)/documents/orders/$(orderId)).data.customerId == request.auth.uid || isAdmin());
        allow create: if isAuthenticated();
      }
    }
  }
}
